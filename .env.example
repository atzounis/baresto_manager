DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Extra hosts (comma-separated). Your LAN IP is auto-added in config/settings/local.py.
ALLOWED_HOSTS_EXTRA=
# Bind address for manage.py runserver (0.0.0.0 = phone/tablet on same Wi‑Fi)
DJANGO_BIND=0.0.0.0
DJANGO_PORT=8765
# Public URL for QR codes and guest menu links.
# In local dev, config/settings/local.py replaces 127.0.0.1 with your LAN IP automatically
# (SITE_BASE_URL_AUTO_LAN=True). Set explicitly to override, e.g. http://192.168.1.42:8765
SITE_BASE_URL=http://127.0.0.1:8765
# Optional override; usually auto-built from ALLOWED_HOSTS in local.py
# CSRF_TRUSTED_ORIGINS=http://192.168.1.42:8765
DATABASE_URL=sqlite:///db.sqlite3
# Optional. Leave unset (or comment out) unless Redis is running locally.
# If set but Redis is down, local settings fall back to in-memory cache automatically.
# REDIS_URL=redis://127.0.0.1:6379/1
USE_INMEMORY_CHANNELS=True
